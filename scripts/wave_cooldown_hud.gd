extends Control
## HUD da onda: desenha corpo, barras e olhos diretamente em código.

const NEON_GREEN := Color(0.25, 1.0, 0.75)
const POWER_BLUE := Color(0.42, 0.95, 1.0)
const POWER_CORE := Color(0.86, 1.0, 1.0)
const SOURCE_SIZE := Vector2(1110.0, 695.0)
const HUD_WIDTH := 360
const HUD_HEIGHT := 225
const HUD_SIZE := Vector2(HUD_WIDTH, HUD_HEIGHT)
const DRAIN_DURATION := 0.42
const LINE_WHITE := Color(0.94, 0.97, 0.94)
const INK_SHADOW := Color(0.0, 0.0, 0.0, 0.78)
const BODY_RASTER_SIZE := Vector2(360.0, 225.0)
const BODY_LINE_B64 := ""

var _cooldown_progress := 1.0
var _display_progress := 1.0
var _wave_ready := true
var _draining := false
var _drain_t := 0.0
var _drain_from := 1.0

var _bar_outline_rects: Array[Rect2] = []
var _bar_fill_rects: Array[Rect2] = []
var _thin_bar_lines: Array[Rect2] = []
var _body_line_bytes := PackedByteArray()

func _ready() -> void:
	anchor_left = 0.0
	anchor_top = 1.0
	anchor_right = 0.0
	anchor_bottom = 1.0
	offset_left = 36.0
	offset_top = -257.0
	offset_right = 396.0
	offset_bottom = -32.0
	custom_minimum_size = HUD_SIZE
	mouse_filter = Control.MOUSE_FILTER_IGNORE

	_make_manual_bar_masks()
	_body_line_bytes = Marshalls.base64_to_raw(BODY_LINE_B64)

	WaveManager.cooldown_changed.connect(_on_cooldown_changed)
	WaveManager.wave_used.connect(_on_wave_used)
	_on_cooldown_changed(WaveManager.get_cooldown_progress(), WaveManager.is_wave_ready())

func _process(delta: float) -> void:
	if _draining:
		_drain_t += delta
		var t := clampf(_drain_t / DRAIN_DURATION, 0.0, 1.0)
		var eased := 1.0 - pow(1.0 - t, 3.0)
		_display_progress = lerpf(_drain_from, 0.0, eased)
		if t >= 1.0:
			_draining = false
			_display_progress = _cooldown_progress
	else:
		_display_progress = _cooldown_progress
	queue_redraw()

func _on_cooldown_changed(progress: float, ready: bool) -> void:
	_cooldown_progress = clampf(progress, 0.0, 1.0)
	_wave_ready = ready
	if not _draining:
		_display_progress = _cooldown_progress

func _on_wave_used() -> void:
	_wave_ready = false
	_draining = true
	_drain_t = 0.0
	_drain_from = 1.0

func _make_manual_bar_masks() -> void:
	# Manual coordinates in the same source-space as the body line art.
	# Fill rects stay inside each outline so the bars remain crisp.
	_bar_outline_rects = [
		Rect2(33, 235, 21, 46),
		Rect2(66, 208, 21, 73),
		Rect2(127, 158, 25, 123),
		Rect2(164, 196, 25, 85),
		Rect2(201, 236, 25, 45),
		Rect2(263, 47, 31, 274),
		Rect2(305, 79, 31, 191),
		Rect2(346, 123, 30, 109),
		Rect2(732, 138, 30, 94),
		Rect2(773, 5, 31, 265),
		Rect2(815, 41, 30, 279),
		Rect2(884, 124, 28, 155),
		Rect2(919, 52, 23, 227),
		Rect2(954, 138, 24, 141),
		Rect2(1020, 166, 24, 113),
		Rect2(1056, 235, 24, 44),
	]
	_bar_fill_rects = [
		Rect2(39, 243, 9, 30),
		Rect2(72, 216, 9, 57),
		Rect2(133, 166, 13, 107),
		Rect2(170, 204, 13, 69),
		Rect2(207, 244, 13, 29),
		Rect2(270, 55, 17, 258),
		Rect2(312, 87, 17, 176),
		Rect2(353, 131, 16, 94),
		Rect2(739, 146, 16, 79),
		Rect2(780, 13, 17, 250),
		Rect2(822, 49, 16, 264),
		Rect2(891, 132, 14, 140),
		Rect2(925, 60, 11, 212),
		Rect2(961, 146, 10, 126),
		Rect2(1027, 174, 11, 98),
		Rect2(1063, 243, 10, 29),
	]
	_thin_bar_lines = [
		Rect2(99, 236, 6, 45),
		Rect2(238, 147, 6, 134),
		Rect2(863, 216, 14, 63),
		Rect2(990, 225, 5, 54),
	]

func _draw() -> void:
	_draw_manual_bar_fills()
	_draw_bar_outlines()
	_draw_power_eyes(false)
	_draw_body_line_art()
	_draw_power_eyes(true)

func _draw_manual_bar_fills() -> void:
	var fill := clampf(_display_progress, 0.0, 1.0)
	if fill <= 0.0:
		return

	for source_rect in _bar_fill_rects:
		var rect := _scale_rect(source_rect)
		var fill_height := rect.size.y * fill
		var fill_rect := Rect2(
			Vector2(rect.position.x, rect.position.y + rect.size.y - fill_height),
			Vector2(rect.size.x, fill_height)
		)
		draw_rect(fill_rect, Color(NEON_GREEN, 0.94), true)

func _draw_bar_outlines() -> void:
	for source_rect in _bar_outline_rects:
		var rect := _scale_rect(source_rect)
		draw_rect(rect.grow(0.4), Color(0.0, 0.0, 0.0, 0.75), false, 3.4)
		draw_rect(rect, LINE_WHITE, false, 1.45)
	for source_rect in _thin_bar_lines:
		var rect := _scale_rect(source_rect)
		var x := rect.position.x + rect.size.x * 0.5
		draw_line(Vector2(x, rect.position.y), Vector2(x, rect.position.y + rect.size.y), Color(0.0, 0.0, 0.0, 0.75), 3.2, true)
		draw_line(Vector2(x, rect.position.y), Vector2(x, rect.position.y + rect.size.y), LINE_WHITE, 1.2, true)

func _draw_power_eyes(over_line: bool) -> void:
	if not (_wave_ready and _display_progress >= 0.995):
		return

	var left := _scale_point(Vector2(482, 286))
	var right := _scale_point(Vector2(630, 286))
	if not over_line:
		for center in [left, right]:
			_draw_filled_ellipse(center, Vector2(18.0, 9.0), Color(POWER_BLUE, 0.10))
			_draw_filled_ellipse(center, Vector2(13.0, 6.0), Color(POWER_BLUE, 0.20))
			_draw_filled_ellipse(center, Vector2(8.2, 3.7), Color(POWER_CORE, 0.62))
		return

	for center in [left, right]:
		_draw_filled_ellipse(center, Vector2(7.0, 3.2), Color(POWER_CORE, 0.88))
		draw_circle(center, 2.4, Color.WHITE)

func _draw_body_line_art() -> void:
	for offset in [
		Vector2(-1.0, 0.0),
		Vector2(1.0, 0.0),
		Vector2(0.0, -1.0),
		Vector2(0.0, 1.0),
		Vector2(0.0, 0.0),
	]:
		_draw_body_line_runs(INK_SHADOW, offset)
	_draw_body_line_runs(LINE_WHITE, Vector2.ZERO)

func _draw_body_line_runs(base_color: Color, offset: Vector2) -> void:
	var scale := size / BODY_RASTER_SIZE
	for i in range(0, _body_line_bytes.size(), 6):
		var y := int(_body_line_bytes[i])
		var x := int(_body_line_bytes[i + 1]) | (int(_body_line_bytes[i + 2]) << 8)
		var w := int(_body_line_bytes[i + 3]) | (int(_body_line_bytes[i + 4]) << 8)
		var alpha := float(_body_line_bytes[i + 5]) / 255.0
		var rect := Rect2(
			Vector2(float(x) * scale.x, float(y) * scale.y) + offset,
			Vector2(maxf(float(w) * scale.x, 1.0), maxf(scale.y, 1.0))
		)
		draw_rect(rect, Color(base_color.r, base_color.g, base_color.b, base_color.a * alpha), true)

func _draw_filled_ellipse(center: Vector2, radius: Vector2, color: Color) -> void:
	var points := PackedVector2Array()
	for i in range(32):
		var t := TAU * float(i) / 32.0
		points.append(center + Vector2(cos(t) * radius.x, sin(t) * radius.y))
	draw_colored_polygon(points, color)

func _scale_point(point: Vector2) -> Vector2:
	return Vector2(point.x * size.x / SOURCE_SIZE.x, point.y * size.y / SOURCE_SIZE.y)

func _scale_rect(rect: Rect2) -> Rect2:
	return Rect2(_scale_point(rect.position), rect.size * size / SOURCE_SIZE)
